# Meta (Facebook) Pixel ID for tracking conversions
VITE_FACEBOOK_PIXEL_ID=

# Custom checkout URL (Stripe, Hotmart, PayPal, or WhatsApp link)
# If left empty, the page will simulate a beautiful secure Stripe checkout with confetti celebration!
VITE_CHECKOUT_URL=

# Custom Hero/Product Preview image (Shows up on the main hero section)
# If left empty, a gorgeous interactive CSS Sheets Simulator card will render instead!
VITE_HERO_IMAGE_URL=

# Custom video URLs (Can be standard YouTube watch URLs, short links, or embed links)
VITE_VIDEO_URL_1=
VITE_VIDEO_URL_2=

# Custom video thumbnails (URLs for cover images)
VITE_VIDEO_THUMBNAIL_1=
VITE_VIDEO_THUMBNAIL_2=

# Custom customer testimonial avatar image URLs
VITE_TESTIMONIAL_AVATAR_1=
VITE_TESTIMONIAL_AVATAR_2=
VITE_TESTIMONIAL_AVATAR_3=

# Custom logo image URL
VITE_LOGO_IMAGE_URL=
